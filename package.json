{
  "name": "ragscope",
  "version": "0.1.0",
  "description": "Instant RAG pipeline audit — instrument once, get scored results in your terminal",
  "keywords": [
    "rag",
    "llm",
    "observability",
    "opentelemetry",
    "otlp",
    "langfuse",
    "retrieval",
    "audit",
    "debugging",
    "vector-search",
    "langchain",
    "llamaindex"
  ],
  "author": "Siddharth Pandey <pandeysiddharth27@gmail.com>",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Sidd27/ragscope.git"
  },
  "homepage": "https://github.com/Sidd27/ragscope#readme",
  "bugs": {
    "url": "https://github.com/Sidd27/ragscope/issues"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "bin": {
    "ragscope": "./dist/bin/ragscope.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc && chmod +x dist/bin/ragscope.js",
    "prepublishOnly": "pnpm run build",
    "dev": "tsx watch bin/ragscope.ts",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.2",
    "ai-tokenizer": "^1.0.6",
    "better-sqlite3": "^12.10.0",
    "chonkie": "^0.3.0",
    "drizzle-orm": "^0.45.2",
    "fastify": "^5.3.2",
    "langfuse": "^3.37.1",
    "picocolors": "^1.1.1"
  },
  "optionalDependencies": {
    "@huggingface/transformers": "^4.2.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.15.21",
    "@vitest/coverage-v8": "^3.2.4",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vitest": "^3.2.1"
  }
}
