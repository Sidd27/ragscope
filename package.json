    "drizzle-orm": "^0.45.2",
    "fastify": "^5.3.2",
    "langfuse": "^3.37.1",
    "picocolors": "^1.1.1"
  },
  "optionalDependencies": {
    "@huggingface/transformers": "^4.2.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.15.21",
    "@vitest/coverage-v8": "^3.2.4",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
