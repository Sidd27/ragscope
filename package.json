{
  "name": "ragscope",
  "version": "0.0.1",
  "description": "Instant RAG pipeline audit — instrument once, get scored results in your terminal",
  "type": "module",
  "bin": {
    "ragscope": "./dist/bin/ragscope.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "pnpm run build",
